														Total
													</div>
												</th>
											</tr>
											</thead>

											<tbody>
											<!-- SIMPLE EXPENSE -->
											<aura:iteration items="{!grantData[1]}" var="r" indexVar="idx">

												<tr id="{!r.key}" class="{!'tr'+r.styleClass}">
													<th>
														<div class="slds-text-align_left">

															<!-- EXPENSE SIMPLE DETAIL COLUMN -->
															<lightning:layout multipleRows="true">
																<lightning:layoutItem padding="around-none"
																					  size="12">
																	<div
																			class="page-section page-header slds-grid_vertical">
																		<div>
																			<lightning:button
																					iconName="utility:delete"
																					class="slds-p-around--none"
