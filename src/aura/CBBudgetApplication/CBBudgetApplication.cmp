													<th>
														<div class="slds-p-left--small slds-m-around_none"
															 style="min-width: 200px;">
															<lightning:button label="{!r.title}"
																			  iconName="utility:edit" variant="base"
																			  class="hideEdge" iconPosition="left"
																			  value="{!r.key}" onclick="{!c.redirectToApp}" />
															<lightning:badge label="APP▲" class="slds-float--right"
