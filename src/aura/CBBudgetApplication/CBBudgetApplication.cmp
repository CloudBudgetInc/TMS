																			<p class="cb-descr-limit hideEdge">
																				{!r.description}</p>
																		</div>
																	</div>
																</lightning:layoutItem>

																<aura:renderIf isTrue="{!v.showMode == true}">
																	<lightning:layoutItem padding="around-none"
																						  size="12" class="detailSection">
																		<lightning:layout>
																			<lightning:layoutItem
																					padding="around-none"
																					class="showMoreDetails" size="6">
																				<div
																						class="page-section page-right">
																					<div class="cssTrunc">{!r.accT}
																					</div>
																					<div class="cssTrunc">{!r.dim6T}
																					</div>
																					<div class="cssTrunc">{!r.dim7T}
																					</div>
																				</div>
																			</lightning:layoutItem>
																			<lightning:layoutItem
																					padding="around-none"
																					class="showMoreDetails" size="6">
																				<div
																						class="page-section page-right">
																					<div class="cssTrunc">{!r.dim8T}
																					</div>
																					<div class="cssTrunc">{!r.dim9T}
																					</div>
																					<div class="cssTrunc">
																						{!r.dim10T}</div>
																				</div>
																			</lightning:layoutItem>
																		</lightning:layout>
																	</lightning:layoutItem>
																</aura:renderIf>
															</lightning:layout>

															<!-- EXPENSE SIMPLE DETAIL COLUMN -->
														</div>
													</th>
													<th class="indexTh">
														<div class="slds-truncate index" title="Index">{!idx + 1}
														</div>
													</th>
													<aura:iteration items="{!r.rowValues}" indexVar="key"
																	var="item">
														<th
																class="{!greaterthan(v.app.cb4__Decimal6__c,key)  ? 'noPaddingNoMargin splitRow' : 'noPaddingNoMargin' }">
															<lightning:input variant="label-hidden" maxlength="9"
																			 label="expense" class="dec" step="0.01"
																			 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
																			 name="{!r.key}" type="number"
																			 onchange="{!c.valueChangeResponse}"
																			 value="{!item.v}" />
														</th>
													</aura:iteration>
												</tr>

											</aura:iteration>
											<!-- SIMPLE EXPENSE -->
											</tbody>
										</table>
									</div>
								</div>
								</aura:iteration>
								<!--GRANTS SECTION-->

							</aura:renderIf>
							<!-- EXPENSE -->

							<div style="height: 200px;"></div>


						</div>
					</div>

				</lightning:tab>
				<lightning:tab label="Details">
					<!-- EXPANDED APP COMMON INFO -->
					<div class="slds-grid slds-wrap" id="expandedView">
						<div class="slds-size_1-of-3">
							<div class="slds-p-around--small slds-text-align_left">
								<lightning:input name="Title" label="Title" aura:id='titleField' maxlength="120"
												 disabled="{!v.editDisabled}" value="{!v.app.Name}" />
							</div>
							<div class="slds-p-around--small slds-text-align_left">
								<lightning:input value="{!v.app.cb4__OrderNumber__c}" label="Order Number"
												 type="number" />
							</div>
							<div class="slds-p-around--small slds-text-align_left">
								<lightning:textarea value="{!v.app.cb4__Text3__c}" label="Description" maxlength="250"
													disabled="{!v.editDisabled}" />
							</div>
						</div>
						<div class="slds-size_1-of-3">

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<lightning:select label="Owner" disabled="{!v.editDisabled}" value="{!v.app.OwnerId}">
									<option value="" text="-" />
									<aura:renderIf isTrue="{!v.app.cb4__Tag2__r.cb4__Boolean6__c}">
										<aura:iteration items="{!v.userAllSO}" var="option">
											<option value="{!option.value}" text="{!option.title}"
													selected="{!v.app.OwnerId == option.value}" />
										</aura:iteration>
										<aura:set attribute="else">
											<aura:iteration items="{!v.userSO}" var="option">
												<option value="{!option.value}" text="{!option.title}"
														selected="{!v.app.OwnerId == option.value}" />
											</aura:iteration>
										</aura:set>
									</aura:renderIf>
									<aura:iteration items="{!v.queueSO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.OwnerId == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<lightning:select label="Parent (admin only)" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag1__c}">
									<option value="" text="-" />
									<aura:iteration items="{!v.appSO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag1__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<lightning:select label="Template (admin only)" disabled="{!v.editDisabled}"
												  required="true" value="{!v.app.cb4__Tag2__c}">
									<aura:iteration items="{!v.templateSO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag2__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<div style="width: 75%; display: inline-block; ">
									<lightning:input type="text" value="{!v.app.cb4__Status__c}"
													 label="Status (admin only)" placeholder="Open" />
								</div>
								<div style="display: inline-block; margin-left: 7px; ">
									<lightning:input type="checkbox" checked="{!v.app.cb4__isLocked__c}"
													 label="Final Status" />
								</div>
							</div>

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<lightning:select label="BY (admin only)" disabled="{!v.editDisabled}" required="true"
												  value="{!v.app.cb4__Tag3__c}">
									<aura:iteration items="{!v.periodSO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag3__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>

							<div
									class="{!v.settingsObj.AdminAppParams == null ? 'slds-hide slds-p-around--small' : v.settingsObj.AdminAppParams + ' slds-p-around--small'}">
								<lightning:select label="{!v.appDim4name + ' (admin only)'}" required="true"
												  value="{!v.app.cb4__Tag4__c}">
									<aura:iteration items="{!v.departmentSO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag4__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>


							<div class="{!empty(v.appDim6SO) + 'hide slds-p-around--small'}">
								<lightning:select label="{!v.appDim6name}" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag6__c}">
									<option value=" " text="-" />
									<aura:iteration items="{!v.appDim6SO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag6__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>
							<div class="{!empty(v.appDim7SO) + 'hide slds-p-around--small '}">
								<lightning:select label="{!v.appDim7name}" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag7__c}">
									<option value=" " text="-" />
									<aura:iteration items="{!v.appDim7SO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag7__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>
							<div class="{!empty(v.appDim8SO) + 'hide slds-p-around--small '}">
								<lightning:select label="{!v.appDim8name}" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag8__c}">
									<option value=" " text="-" />
									<aura:iteration items="{!v.appDim8SO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag8__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>
							<div class="{!empty(v.appDim9SO) + 'hide slds-p-around--small '}">
								<lightning:select label="{!v.appDim9name}" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag9__c}">
									<option value=" " text="-" />
									<aura:iteration items="{!v.appDim9SO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag9__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>
							<div class="{!empty(v.appDim10SO) + 'hide slds-p-around--small '}">
								<lightning:select label="{!v.appDim10name}" disabled="{!v.editDisabled}"
												  value="{!v.app.cb4__Tag10__c}">
									<option value=" " text="-" />
									<aura:iteration items="{!v.appDim10SO}" var="option">
										<option value="{!option.value}" text="{!option.title}"
												selected="{!v.app.cb4__Tag10__c == option.value}" />
									</aura:iteration>
								</lightning:select>
							</div>

						</div>
						<div class="slds-size_1-of-3">

							<lightning:tile label="App Details">
								<dl class="slds-dl_horizontal slds-p-around--small">
									<dt class="slds-dl_horizontal__label">Template:</dt>
									<dd class="slds-dl_horizontal__detail">
										<a href="{!'/'+ v.template.Id}" target="_blank>">
											{!v.app.cb4__Tag2Name__c}
										</a>
									</dd>

									<dt class="slds-dl_horizontal__label">Approach:</dt>
									<dd class="slds-dl_horizontal__detail">{!v.template.cb4__Text1__c }</dd>

									<dt class="slds-dl_horizontal__label">Type:</dt>
									<dd class="slds-dl_horizontal__detail">{!v.template.cb4__Text2__c}</dd>

									<dt class="slds-dl_horizontal__label">Period:</dt>
									<dd class="slds-dl_horizontal__detail">{!v.app.cb4__Tag3Name__c}</dd>

									<dt class="slds-dl_horizontal__label">Calc Rule(s):</dt>
									<dd class="slds-dl_horizontal__detail">
										<a href="{!'/'+ v.template.cb4__Tag4__c}" target="_blank>">
											{!v.template.cb4__Tag4Name__c}
										</a>
									</dd>

									<dt class=" slds-dl_horizontal__label">Status:</dt>
									<dd class="slds-dl_horizontal__detail">{!v.app.cb4__Status__c}</dd>

								</dl>
							</lightning:tile>
							<aura:renderIf isTrue="{!v.appDimension.cb4__File1__c.vi == 't'}">
								<lightning:fileUpload name="fileUploader1" label="{!v.appDimension.cb4__File1__c.v}"
													  multiple="false" accept=".pdf, .csv, .xls, .xlsx, .png, .jpeg"
													  recordId="{!v.app.Id}" onuploadfinished="{! c.handleUploadFinished }" />
							</aura:renderIf>
							<aura:renderIf isTrue="{!v.appDimension.cb4__File2__c.vi == 't'}">
								<div class="slds-tile slds-m-top_small">
									<h3 class="slds-truncate" title="{!v.appDimension.cb4__File2__c.v}">
										<a data-aura-rendered-by="1852:0"
										   href="javascript:void(0);">{!v.appDimension.cb4__File2__c.v}</a>
									</h3>
									<div class="slds-tile__detail slds-text-body_small">
										<dl class="slds-dl_horizontal slds-p-around_small">
											<aura:renderIf isTrue="{!v.attachments.length == 0}">
												<dt class=" slds-dl_horizontal__label"></dt>
												<dd class="slds-dl_horizontal__detail">
													<p>No files found</p>
												</dd>
											</aura:renderIf>
											<aura:iteration items="{!v.attachments}" var="attachment"
															indexVar="counter">
												<dt class=" slds-dl_horizontal__label">{!counter + 1}.</dt>
												<dd class="slds-dl_horizontal__detail">
													<a href="{!attachment.url}" target="_blank">{!attachment.Title}</a>
												</dd>
											</aura:iteration>
										</dl>
									</div>
								</div>
							</aura:renderIf>
						</div>

					</div>
					<!-- EXPANDED APP COMMON INFO -->
				</lightning:tab>
			</lightning:tabset>
		</lightning:card>
		<div class="slds-card slds-card slds-p-top--small slds-p-bottom--small slds-p-left--xxx-small"
			 aura:id="excelPanel"
			 style="width: 380px; opacity: 0.9; position: fixed; top: 220px; right:-350px;  box-shadow: 0px 0px 5px;">

			<lightning:layout>
				<lightning:layoutItem>
					<div onclick="{!c.showExcelPanel}" class="excelPanel">
						<div>
							<lightning:icon iconName="doctype:excel" size="medium" alternativeText="Excel" />
						</div>
					</div>
				</lightning:layoutItem>
				<lightning:layoutItem class="slds-p-left--small">
					<lightning:button label="Download Simple Lines" iconName="utility:download"
									  class="slds-m-left--xx-small slds-text-body_small slds-nowrap" iconPosition="left"
									  onclick="{!c.downloadExcel}" />

				</lightning:layoutItem>
				<lightning:layoutItem title="Uploading is available only in the Open status">
					<lightning:input type="file" variant="label-hidden" disabled="{!v.app.cb4__Status__c != 'Open'}"
									 class="slds-text-body_small slds-nowrap" multiple="false" accept=".xlsx, .xlx"
									 onchange="{!c.handleFilesChange}" />
				</lightning:layoutItem>
			</lightning:layout>

		</div>

	</aura:renderIf>
	<!-- SINGLE -->

	<!-- ONE LINE INTERFACE -->
	<section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aura:id="modalDiv"
			 aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_large slds-hide">
		<div class="slds-modal__container">
			<header class="slds-modal__header">
				<h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">{!v.row.title}</h2>
				<lightning:badge class="slds-float--right" label="{!v.row.ie}" />
			</header>
			<div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">

				<lightning:layout>
					<lightning:layoutItem padding="around-small">
						<div>
							<lightning:buttonIcon iconName="utility:level_down" size="small" value="{!v.row.key}"
												  alternativeText="Convert to Simple Row" onclick="{!c.convertToSimpleRow}"
												  class="{!v.row.styleClass + 'slds-hide slds-m-bottom_xx-small'}" />
						</div>
					</lightning:layoutItem>
					<lightning:layoutItem padding="around-small">
						<div class="slds-m-around_none">
							<lightning:input type="text" disabled="{!v.editDisabled}" placeholder="Put in some title"
											 messageWhenTooLong="You cannot use more than 250 characters" label="Title"
											 maxlength="250" value="{!v.row.title}" />
						</div>

						<div class="slds-m-around_none ">
							<lightning:select name="{!v.row.key}" disabled="{!v.editDisabled}" label="CB Account"
											  required="true" accesskey="account" messageWhenValueMissing="Please specify account"
											  onchange="{!c.updateAppLineTitle}" value="{!v.row.account}">
								<aura:iteration items="{!v.rowAccountSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.account == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>
					</lightning:layoutItem>

					<lightning:layoutItem padding="around-small">
						<div class="{!or(empty(v.d6SO), v.amountDimension.cb4__Dimension6__c.vi == 'f')+ 'hide slds-m-around_none'}">
							<lightning:select disabled="{!v.editDisabled}" onchange="{!c.updateAppLineTitle}"
											  label="{!v.d6name}" accesskey="dimension6" value="{!v.row.dim6}">
								<option value="" text="-" />
								<aura:iteration items="{!v.d6SO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.dim6 == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>

						<div class="{!or(empty(v.d7SO), v.amountDimension.cb4__Dimension7__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:select disabled="{!v.editDisabled}" onchange="{!c.updateAppLineTitle}"
											  label="{!v.d7name}" accesskey="dimension7" value="{!v.row.dim7}">
								<option value="" text="-" />
								<aura:iteration items="{!v.d7SO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.dim7 == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>

						<div class="{!or(empty(v.d8SO), v.amountDimension.cb4__Dimension8__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:select disabled="{!v.editDisabled}" onchange="{!c.updateAppLineTitle}"
											  label="{!v.d8name}" accesskey="dimension8" value="{!v.row.dim8}">
								<option value="" text="-" />
								<aura:iteration items="{!v.d8SO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.dim8 == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>

						<div class="{!or(empty(v.d9SO), v.amountDimension.cb4__Dimension9__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:select disabled="{!v.editDisabled}" onchange="{!c.updateAppLineTitle}"
											  label="{!v.d9name}" accesskey="dimension9" value="{!v.row.dim9}">
								<option value="" text="-" />
								<aura:iteration items="{!v.d9SO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.dim9 == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>

						<div class="{!or(empty(v.d10SO), v.amountDimension.cb4__Dimension10__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:select disabled="{!v.editDisabled}" onchange="{!c.updateAppLineTitle}"
											  label="{!v.d10name}" accesskey="dimension10" value="{!v.row.dim10}">
								<option value="" text="-" />
								<aura:iteration items="{!v.d10SO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.dim10 == option.value}" />
								</aura:iteration>
							</lightning:select>
						</div>
					</lightning:layoutItem>

					<!-- ADDITIONAL LINE TEXT -->
					<lightning:layoutItem padding="around-small">
						<div class="{!(v.amountDimension.cb4__Text6__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Text6__c}" maxlength="250" type="text" value="{!v.row.text6}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Text7__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Text7__c}" maxlength="250" type="text" value="{!v.row.text7}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Text8__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Text8__c}" maxlength="250" type="text" value="{!v.row.text8}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Text9__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Text9__c}" maxlength="250" type="text" value="{!v.row.text9}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
					</lightning:layoutItem>
					<!-- ADDITIONAL LINE TEXT -->

					<!-- ADDITIONAL LINE DECIMAL -->
					<lightning:layoutItem padding="around-small">
						<div class="{!(v.amountDimension.cb4__Decimal6__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Decimal6__c}" maxlength="9" type="number"
											 value="{!v.row.decimal6}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Decimal7__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Decimal7__c}" maxlength="9" type="number"
											 value="{!v.row.decimal7}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Decimal8__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Decimal8__c}" maxlength="9" type="number"
											 value="{!v.row.decimal8}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Decimal9__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Decimal9__c}" maxlength="9" type="number"
											 value="{!v.row.decimal9}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
						<div class="{!(v.amountDimension.cb4__Decimal10__c.vi == 'f') + 'hide slds-m-around_none'}">
							<lightning:input label="{!v.Decimal10__c}" maxlength="9" type="number"
											 value="{!v.row.decimal10}" disabled="{!or(v.editDisabled, v.amountDimension.cb4__Boolean1__c.d == 't')}"/>
						</div>
					</lightning:layoutItem>
					<!-- ADDITIONAL LINE DECIMAL -->

					<!--ADDITIONAL LINE BOOLEANS-->
					<lightning:layoutItem class="slds-p-top_x-large">
						<div class="{!(v.amountDimension.cb4__Boolean1__c.vi == 'f') + 'hide'}">
							<lightning:input type="checkbox"
											 name="cb4__Boolean1__c"
											 label="{!v.amountDimension.cb4__Boolean1__c.v}"
											 checked="{!v.row.boolean1}"
											 disabled="{!or(v.editDisabled,v.amountDimension.cb4__Boolean1__c.d == 't')}" />

						</div>
						<div class="{!(v.amountDimension.cb4__Boolean2__c.vi == 'f') + 'hide'}">
							<lightning:input type="checkbox"
											 name="cb4__Boolean2__c"
											 label="{!v.amountDimension.cb4__Boolean2__c.v}"
											 checked="{!v.row.boolean2}"
											 disabled="{!or(v.editDisabled,v.amountDimension.cb4__Boolean2__c.d == 't')}" />
						</div>
						<div class="{!(v.amountDimension.cb4__Boolean3__c.vi == 'f') + 'hide'}">
							<lightning:input type="checkbox"
											 name="cb4__Boolean3__c"
											 label="{!v.amountDimension.cb4__Boolean3__c.v}"
											 checked="{!v.row.boolean3}"
											 disabled="{!or(v.editDisabled,v.amountDimension.cb4__Boolean3__c.d == 't')}" />
						</div>
						<div class="{!(v.amountDimension.cb4__Boolean4__c.vi == 'f') + 'hide'}">
							<lightning:input type="checkbox"
											 name="cb4__Boolean4__c"
											 label="{!v.amountDimension.cb4__Boolean4__c.v}"
											 checked="{!v.row.boolean4}"
											 disabled="{!or(v.editDisabled,v.amountDimension.cb4__Boolean4__c.d == 't')}" />
						</div>
						<div class="{!(v.amountDimension.cb4__Boolean5__c.vi == 'f') + 'hide'}">
							<lightning:input type="checkbox"
											 name="cb4__Boolean5__c"
											 label="{!v.amountDimension.cb4__Boolean5__c.v}"
											 checked="{!v.row.boolean5}"
											 disabled="{!or(v.editDisabled,v.amountDimension.cb4__Boolean5__c.d == 't')}" />
						</div>
					</lightning:layoutItem>
					<!--ADDITIONAL LINE BOOLEANS-->

					<aura:if isTrue="{!v.template.cb4__Text2__c == 'Rate and Quantity'}">
						<lightning:layoutItem size="4" padding="around-small">

							<lightning:select disabled="{!v.editDisabled}" label="Product" onchange="{!c.setPrice}"
											  value="{!v.row.productId}">
								<option value="" text="-" />
								<aura:iteration items="{!v.productSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.productId == option.value}" />
								</aura:iteration>
							</lightning:select>

							<lightning:select disabled="{!v.editDisabled}" label="Price Book" onchange="{!c.setPrice}"
											  value="{!v.row.pricebookId}">
								<option value="" text="-" />
								<aura:iteration items="{!v.pricebookSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.pricebookId == option.value}" />
								</aura:iteration>
							</lightning:select>
						</lightning:layoutItem>
					</aura:if>


					<aura:if isTrue="{!v.template.cb4__Text2__c == 'Employee and Rate'}">
						<lightning:layoutItem size="4" padding="around-small">
							<lightning:select disabled="{!v.editDisabled}" label="Employee" accesskey="empRate"
											  onchange="{!c.setRate}" value="{!v.row.employeeId}">
								<option value="" text="-" />
								<aura:iteration items="{!v.employeeSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.employeeId == option.value}" />
								</aura:iteration>
							</lightning:select>

							<lightning:select disabled="{!v.editDisabled}" label="Rate" accesskey="empRate"
											  onchange="{!c.setRate}" value="{!v.row.rateId}">
								<option value="" text="-" />
								<aura:iteration items="{!v.rateSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.rateId == option.value}" />
								</aura:iteration>
								<aura:iteration items="{!v.globalRateSO}" var="option">
									<option value="{!option.value}" text="{!option.title}"
											selected="{!v.row.rateId == option.value}" />
								</aura:iteration>
							</lightning:select>
						</lightning:layoutItem>
					</aura:if>


					<lightning:layoutItem size="4" padding="around-small">
						<div class="slds-m-around_none">
							<lightning:textarea onblur="{!c.updateAppLineTitle}" disabled="{!v.editDisabled}"
												accesskey="description" maxlength="250"
												messageWhenTooLong="You cannot use more than 250 characters" placeholder="Description"
												label="Description" value="{!v.row.description}" />
						</div>
					</lightning:layoutItem>

				</lightning:layout>

				<aura:if isTrue="{!v.row != null}">
					<table class="slds-table slds-table_cell-buffer slds-table_bordered">
						<thead>
						<tr class="slds-line-height_reset">
							<th>

							</th>

							<aura:iteration items="{!v.headers}" var="h">
								<th>
									<div class="slds-truncate slds-text-align--right" title="Period">{!h}</div>
								</th>
							</aura:iteration>
							<th>
								<div class="slds-truncate slds-text-align--right" title="Total">
									Total
								</div>
							</th>
						</tr>
						</thead>
						<tbody>

						<tr>
							<th>
								<lightning:icon iconName="utility:money" alternativeText="Money" title="Money"
												size="small" variant="success" />
							</th>
							<aura:iteration items="{!v.row.rowValues}" var="item">
								<th class="noPaddingNoMargin">
									<lightning:input variant="label-hidden" maxlength="9" class="dec" step="0.01"
													 placeholder="Enter a number"
													 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
													 onchange="{!c.calculateDialogTotals}" value="{!item.v}" type="number" />
								</th>
							</aura:iteration>
						</tr>

						<!-- PRICE & QUANTITY -->
						<aura:if
								isTrue="{! and( (v.template.cb4__Text2__c == 'Rate and Quantity') , (v.row.productId != null) )}">
							<tr>
								<th>
									<lightning:icon iconName="utility:cart" alternativeText="Quantity"
													title="Quantity" size="small" />
								</th>
								<aura:iteration items="{!v.row.rowValues}" var="item">
									<th class="noPaddingNoMargin">
										<lightning:input variant="label-hidden" maxlength="9" class="dec" step="1"
														 min="0" placeholder="Put a number"
														 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
														 onchange="{!c.calculateDialogTotals}" value="{!item.q}" type="number" />
									</th>
								</aura:iteration>
							</tr>
							<tr>
								<th>
									<lightning:icon iconName="utility:graph" alternativeText="Price/Rate"
													title="Price/Rate" size="small" />
								</th>
								<aura:iteration items="{!v.row.rowValues}" var="item" indexVar="i"
												end="{!v.row.rowValues.length - 1}">
									<th class="noPaddingNoMargin">
										<lightning:input variant="label-hidden" maxlength="9" class="dec"
														 step="0.01" placeholder="Enter a number"
														 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
														 onchange="{!c.calculateDialogTotals}" value="{!item.p}" type="number" />
									</th>
								</aura:iteration>
							</tr>
						</aura:if>
						<!-- PRICE & QUANTITY -->


						<!-- EMPLOYEE & RATE -->
						<aura:if
								isTrue="{! and( (v.template.cb4__Text2__c == 'Employee and Rate') , (v.row.rateId != null) )}">
							<tr>
								<th>
									<lightning:icon iconName="utility:reminder" alternativeText="Hours"
													title="Hours" size="small" />
								</th>
								<aura:iteration items="{!v.row.rowValues}" var="item">
									<th class="noPaddingNoMargin">
										<lightning:input variant="label-hidden" maxlength="9" class="dec" step="0.1"
														 min="0" placeholder="Enter a number"
														 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
														 onchange="{!c.calculateDialogTotals}" value="{!item.q}" type="number" />
									</th>
								</aura:iteration>
							</tr>
							<tr>
								<th>
									<lightning:icon iconName="utility:resource_capacity" alternativeText="Rate"
													title="Rate" size="small" />
								</th>
								<aura:iteration items="{!v.row.rowValues}" var="item"
												end="{!v.row.rowValues.length - 1}">
									<th class="noPaddingNoMargin">
										<lightning:input variant="label-hidden" maxlength="9" class="dec"
														 step="0.01" placeholder="Enter a number"
														 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
														 onchange="{!c.calculateDialogTotals}" value="{!item.p}" type="number" />
									</th>
								</aura:iteration>
							</tr>
						</aura:if>
						<!-- EMPLOYEE & RATE -->


						</tbody>
					</table>
					<!-- Additional Budget Line Component -->
					<div>
						{!v.additionalBudgetLineComponent}
					</div>
					<!-- Additional Budget Line Component -->
				</aura:if>
			</div>

			<footer class="slds-modal__footer">

				<aura:renderIf isTrue="{!v.template.cb4__Text2__c == 'Totals'}">
					<div>
						<div class="slds-float_left" style="width: 10%;"
							 title="To fill in the line enter the base amount and select an action">
							<lightning:input type="number" placeholder="Base amount" aura:id="dialogSourceAmount"
											 step="0.01" disabled="{!v.editDisabled}"
											 class="dec slds-float_right slds-m-left_xx-large " variant="label-hidden" />
						</div>
						<div class="slds-float_left" title="Relations">
							<lightning:buttonMenu alternativeText="Population menu" variant="border-filled"
												  iconName="utility:magicwand" disabled="{!v.editDisabled}"
												  onselect="{!c.applyPopulation}">
								<lightning:menuItem value="spread" label="Spread" />
								<lightning:menuItem value="splitBY" label="Split by periods" />
								<lightning:menuItem value="multiply" label="Multiply by" />
								<lightning:menuItem value="divide" label="Divide by" />
								<lightning:menuItem value="increase" label="Increase by" />
								<lightning:menuItem value="back" label="Reset" />
								<lightning:menuItem value="pattern" label="Apply pattern" disabled="true" />
							</lightning:buttonMenu>
						</div>
					</div>

				</aura:renderIf>

				<button class="slds-button slds-button_neutral" onclick="{!c.closeDetails}">Cancel</button>
				<aura:renderIf isTrue="{!v.template.cb4__Text2__c == 'Totals'}">
					<button class="slds-button slds-button_neutral" onclick="{!c.applyDetailsAndClone}" disabled="{!v.editDisabled}">Clone</button>
					<button class="slds-button slds-button_success" onclick="{!c.applyDetailsAndNew}" disabled="{!v.editDisabled}">Apply &#38;
						New</button>
				</aura:renderIf>
				<button class="slds-button slds-button_success" onclick="{!c.applyDetails}" disabled="{!v.editDisabled}">Apply</button>

			</footer>
		</div>
	</section>
	<div class="slds-backdrop slds-backdrop_open slds-hide" style="z-index: 3000;" aura:id="modalBackGround"></div>
	<!-- ONE LINE INTERFACE -->

	<!-- BACKUP -->
	<section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aura:id="backupDiv"
			 aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_small slds-hide">
		<div class="slds-modal__container">
			<header class="slds-modal__header">
				<h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">{!v.app.Name} History</h2>
			</header>
			<div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">
				<table class="slds-table slds-table_cell-buffer slds-table_bordered">
					<thead>
					<tr class="slds-line-height_reset">
						<th>
							<div class="slds-truncate" style="width: 10px;" title="Index">#</div>
						</th>
						<th>
							<div class="slds-truncate" title="Title">Title</div>
						</th>
						<th>
							<div class="slds-truncate" title="User">User</div>
						</th>
						<th>
							<div class="slds-truncate" title="Action Date">Action Date</div>
						</th>
						<th style="width: 30px;">
							<div class="slds-truncate" title="Action">Action</div>
						</th>
						<th style="width: 10px;">
							<div class="slds-truncate" title="CBLog">CBLog</div>
						</th>
					</tr>
					</thead>
					<tbody>
					<aura:iteration items="{!v.backupList}" var="backup" indexVar="i">
						<tr class="slds-hint-parent">
							<th>
								{!i + 1}
							</th>
							<th>
								{!backup.cb4__Title__c}
							</th>
							<td>
								{!backup.Owner.Name}
							</td>
							<td>
								<lightning:formattedDateTime value="{!backup.CreatedDate}" year="numeric"
															 month="numeric" day="numeric" hour="2-digit" minute="2-digit" timeZone="UTC"
															 timeZoneName="short" hour12="false" />
							</td>
							<td>
								<lightning:button label="Restore" iconPosition="left" value="{!backup.Id}"
												  onclick="{!c.applyBackup}" />
							</td>
							<td>
								<a href="{!'/' + backup.Id}"> {! backup.Name } </a>
							</td>
						</tr>
					</aura:iteration>
					</tbody>
				</table>
			</div>

			<footer class="slds-modal__footer">
				<lightning:buttonGroup>
					<lightning:button onclick="{!c.hideBackup}" variant="neutral" label="Cancel" />
					<lightning:button onclick="{!c.refreshBackupList}" variant="brand" iconName="utility:refresh" />
				</lightning:buttonGroup>
			</footer>
		</div>
	</section>
	<!-- BACKUP -->


	<!-- AUTOFILL -->
	<section role="dialog" tabindex="-1" aria-labelledby="modal-heading-01" aria-modal="true" aura:id="generatorModal"
			 aria-describedby="modal-content-id-1" class="slds-modal slds-fade-in-open slds-modal_small slds-hide">
		<div class="slds-modal__container">
			<header class="slds-modal__header">
				<h2 id="modal-heading-01" class="slds-modal__title slds-hyphenate">Generator Settings</h2>
			</header>
			<div class="slds-modal__content slds-p-around_medium" id="modal-content-id-1">

				<lightning:select label="Generate Lines Split by" value="{!v.generateLinesByType}">
					<aura:iteration items="{!v.generateLinesByTypeSO}" var="option">
						<option value="{!option}" text="{!option}" />
					</aura:iteration>
				</lightning:select>

			</div>

			<footer class="slds-modal__footer">

				<button class="slds-button slds-button_neutral" onclick="{!c.closeDetails}">Cancel</button>
				<button class="slds-button slds-button_brand" onclick="{!c.generateAppLines}">Generate</button>

			</footer>
		</div>
	</section>
	<div class="slds-backdrop slds-backdrop_open slds-hide" style="z-index: 3000;" aura:id="generatorBackGround"></div>
	<!-- AUTOFILL -->

	<!--Notification Section-->
	<div aura:id="cbnotification" class="slds-hide" style="height:4.5rem">
		<div class="slds-notification-container">
			<section class="slds-notification" role="dialog" aria-labelledby="noti-332"
					 aria-describedby="dialog-body-id-331">
				<div class="slds-notification__body" id="dialog-body-id-331">
					<a class="slds-notification__target slds-media" style="background: #fedfd0;" href="#">
                        <span class="slds-icon_container slds-media__figure" title="Warning">
                            <lightning:icon iconName="utility:report_issue" variant="warning" size="small" />
                            <span class="slds-assistive-text">Warning</span>
                        </span>
						<div class="slds-media__body">
							<h2 class="slds-text-heading_small slds-m-bottom_xx-small" id="noti-332">
								Helpful Hint</h2>
							<p>Your monitor resolution is not optimal, zoom out for a better user experience</p>
						</div>
					</a>
					<button
							class="slds-button slds-button_icon slds-button_icon-container slds-notification__close slds-m-right_small">
						<lightning:buttonIcon iconName="utility:close" variant="bare" value="{!false}"
											  onclick="{! c.hideNotification}" title="Close" />
						<lightning:buttonIcon iconName="utility:turn_off_notifications" variant="bare" value="{!true}"
											  onclick="{! c.hideNotification}" title="Close and turn off notification" />
						<span class="slds-assistive-text">Close</span>
					</button>
				</div>
			</section>
		</div>
	</div>
	<!--Notification Section-->

	<!-- SUPER MODERN SPINNER -->
	<lightning:spinner aura:id="sms" class="slds-hide" />
	<!-- SUPER MODERN SPINNER -->


</aura:component>