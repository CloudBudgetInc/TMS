														</div>
													</th>
													<th class="indexTh">
														<div class="{!r.status == 'Posted' ? 'posted slds-truncate index ' : 'unposted slds-truncate index '}"
															 title="{!'Sub App is ' + r.status}">{!idx + 1}
														</div>
													</th>
													<aura:iteration items="{!r.rowValues}" indexVar="key"
