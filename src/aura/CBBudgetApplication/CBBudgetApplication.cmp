														<th class="noPaddingNoMargin">
															<lightning:input variant="label-hidden" maxlength="9"
																			 disabled="true" class="dec" step="0.01"
																			 name="{!r.key}" label="expense" type="number"
																			 value="{!item.v}" />
														</th>
													</aura:iteration>
												</tr>
											</aura:iteration>
											<!-- SUB DOWN UP  EXPENSE -->

											<!-- SUB TOP DOWN EXPENSE -->
											<aura:iteration items="{!v.expenseTopDownSubData}" var="r"
															indexVar="idx">
												<tr class="slds-hint-parent">
													<th>
														<div class="slds-p-left--small slds-m-around_none"
															 style="min-width: 200px;">
															<lightning:button label="{!r.title}"
																			  iconName="utility:edit" class="hideEdge"
																			  variant="base" iconPosition="left" value="{!r.key}"
																			  onclick="{!c.redirectToApp}" />
															<lightning:badge label="APP▼" class="slds-float--right"
																			 title="Top-Down Sub App" />
															<aura:renderIf isTrue="{!r.description == '0'}">
																<lightning:badge label="✓"
																				 class="slds-float--right greenLabel"
																				 title="Approximately Match" />
																<aura:set attribute="else">
																	<aura:renderIf isTrue="{!r.remain > 0 }">
																		<lightning:icon iconName="utility:arrowdown"
																						size="x-small" title="{!r.description}"
																						class="slds-float--right yellowLabel slds-p-horizontal_x-small slds-p-vertical_xx-small slds cb-bl-limit" />
																		<aura:set attribute="else">

																			<lightning:icon
																					iconName="utility:arrowup"
																					size="x-small"
																					title="{!r.description}"
																					class="slds-float--right yellowLabel slds-p-horizontal_x-small slds-p-vertical_xx-small slds cb-bl-limit" />
																		</aura:set>
																	</aura:renderIf>
																</aura:set>

															</aura:renderIf>
														</div>
													</th>
													<th class="indexTh">
														<div class="{!r.status == 'Posted' ? 'posted slds-truncate index ' : 'unposted slds-truncate index '}"
															 title="{!'Sub App is ' + r.status}">{!idx + 1}
														</div>
													</th>
													<aura:iteration items="{!r.rowValues}" indexVar="key"
																	var="item">
														<th class="noPaddingNoMargin">
															<lightning:input variant="label-hidden" maxlength="9"
																			 disabled="{!or(item.t == 'disabled', v.editDisabled)}"
																			 class="dec" step="0.01" name="{!r.key}"
																			 label="expense" type="number"
																			 onchange="{!c.valueChangeResponse}"
																			 value="{!item.v}" />
														</th>
													</aura:iteration>
												</tr>
											</aura:iteration>
											<!-- SUB TOP DOWN  EXPENSE -->

											</tbody>
										</table>
									</div>
								</div>
								<!--GRANT SECTION-->
								<aura:iteration items="{!v.grantExpenseData}" var="grantData" indexVar="i">
