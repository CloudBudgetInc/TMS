																			<lightning:button label="{!r.title}"
																							  class="hideEdge"
																							  iconName="utility:edit"
																							  variant="base" iconPosition="left"
																							  value="{!r.key}"
																							  onclick="{!c.showDetails}" />
																			<lightning:helptext
																					class="slds-float--right"
																					content="{!r.description}" />
																			<lightning:icon
																					iconName="utility:formula"
																					alternativeText="Calculated"
